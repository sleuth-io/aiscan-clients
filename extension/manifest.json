{
  "manifest_version": 3,
  "name": "aiscan claude.ai capture",
  "version": "0.0.2",
  "description": "Pull your claude.ai conversations and upload them to a Pulse aiscan instance for analysis.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://dev.pulse.sleuth.io/*",
    "https://dev.pulse.sleuth.io/*",
    "https://app.skills.new/*"
  ],
  "background": { "service_worker": "background.js", "scripts": ["background.js"] },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "aiscan claude.ai capture"
  },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "browser_specific_settings": {
    "gecko": { "id": "aiscan-spike@sleuth.io", "strict_min_version": "115.0" }
  }
}
