{
  "manifest_version": 3,
  "name": "Sleuth AI Insights",
  "version": "0.0.0",
  "description": "Captures your claude.ai, chatgpt.com, and gemini.google.com conversations and uploads a redacted copy to Sleuth for analysis.",
  "permissions": ["storage", "tabs", "history", "alarms"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "http://dev.pulse.sleuth.io/*",
    "https://dev.pulse.sleuth.io/*",
    "https://app.skills.new/*"
  ],
  "background": { "service_worker": "background.js", "scripts": ["background.js"] },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Open Sleuth AI Insights",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-insights@sleuth.io",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["personalCommunications", "websiteContent"]
      }
    }
  }
}
